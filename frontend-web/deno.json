{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.1.2",
    "@preact/signals": "npm:@preact/signals@^2.9.1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.1",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.2",
    "tailwindcss": "npm:tailwindcss@4.3.1",
    "tailwindcss/": "npm:/tailwindcss@4.3.1/",
    "tailwindcss/plugin": "npm:/tailwindcss@4.3.1/plugin.js",
    "vite": "npm:vite@8.0.16"
  },
  "lint": {
    "rules": {
      "exclude": [
        "jsx-no-useless-fragment",
        "jsx-curly-braces"
      ],
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "build": "deno task gen:data; deno task check && deno --allow-run vite_build.ts",
    "build:try": "vite build --configLoader=native",
    "check": "deno task gen:data; deno fmt --check && deno lint && deno check **/*.ts && deno check **/*.tsx",
    "gen:data": "./scripts/generate_data.sh && deno fmt",
    "gen:voice_list": "./scripts/generate_voice_list.sh && deno fmt",
    "preview": "deno task gen:data; deno task check && deno serve -A _fresh/server.js",
    "start": "deno task gen:data; vite --port=8000 --configLoader=native ",
    "update": "deno run -A -r jsr:@fresh/update ."
  }
}
